rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Permite lectura pública a videos e imágenes, pero escritura solo a usuarios autenticados
    match /videos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Permite lectura pública a los avatars, y escritura solo al usuario dueño de ese avatar
    match /avatars/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (userId == request.auth.uid || userId == request.auth.uid + '.png');
    }
    // Permite lectura pública a las imágenes de productos, y escritura solo a usuarios autenticados
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
