<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Poptok" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/poptok_red</item>
        <item name="colorPrimaryVariant">@color/poptok_pink</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/poptok_coin</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/poptok_dark</item>
        <item name="colorSurface">@color/poptok_surface</item>
        <item name="colorOnSurface">@color/poptok_text_primary</item>
        <item name="android:windowBackground">@color/poptok_dark</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/poptok_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:textColorPrimary">@color/poptok_text_primary</item>
        <item name="android:textColorSecondary">@color/poptok_text_secondary</item>
    </style>

    <style name="Theme.Poptok.Splash" parent="Theme.Poptok">
        <item name="android:windowBackground">@color/poptok_dark</item>
    </style>

    <!-- Bottom Sheet dialog theme -->
    <style name="Theme.Poptok.BottomSheet" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="android:colorBackground">@color/poptok_surface</item>
        <item name="bottomSheetStyle">@style/Widget.Poptok.BottomSheet</item>
    </style>

    <style name="Widget.Poptok.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="backgroundTint">@color/poptok_surface</item>
        <item name="android:backgroundTint">@color/poptok_surface</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.Poptok.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/poptok_red</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
    </style>

    <style name="Widget.Poptok.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/poptok_text_primary</item>
        <item name="strokeColor">@color/poptok_border</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
    </style>
</resources>